# ── Supabase (required for MVP) ──────────────────────────────────────
# Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Same page — service_role key (e2e/agent only; NEVER prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=

# Project Settings → General → Reference ID
SUPABASE_PROJECT_ID=

# Account → Access Tokens → https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# ── Vercel (required for deploy) ─────────────────────────────────────
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# ── App ──────────────────────────────────────────────────────────────
VITE_APP_URL=

# ── Phase 5: Web Push (optional) ─────────────────────────────────────
# Generate via: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── E2E / local dev overrides ────────────────────────────────────────
PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173
